# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase JWT Secret (for verifying user JWTs issued by Supabase Auth)
# Found in: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# AI — Mistral
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-api-key-here

# Google Maps (optional — for server-side geocoding if needed)
GOOGLE_MAPS_API_KEY=

# App Config
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
